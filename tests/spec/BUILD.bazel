load("//build:wast_test.bzl", "wast_multi_func_test")

# =============================================================================
# Official WebAssembly Spec Test Suite — Bazel integration
#
# These targets compile spec-testsuite .wast files with synth and run them
# on the Renode Cortex-M4 emulator. Files are grouped by category.
#
# Only files that synth can compile (single-module with exports, no SIMD/GC)
# are included. Files marked no_optimize = True previously required the
# optimizer bypass due to register allocation pressure.
#
# To run all spec tests:
#   bazel test //tests/spec/...
#
# To run a specific category:
#   bazel test //tests/spec/... --test_tag_filters=i32
# =============================================================================

# Export all .wast files so they can be referenced from other packages
# .wast files live in //tests/spec-testsuite (git submodule)

# =============================================================================
# i32 — Core 32-bit integer operations
# =============================================================================

wast_multi_func_test(
    name = "spec_i32",
    wast = "//tests/spec-testsuite:i32.wast",
    tags = ["spec", "i32"],
)

wast_multi_func_test(
    name = "spec_int_exprs",
    wast = "//tests/spec-testsuite:int_exprs.wast",
    tags = ["spec", "i32", "i64", "expressions"],
)

wast_multi_func_test(
    name = "spec_int_literals",
    wast = "//tests/spec-testsuite:int_literals.wast",
    tags = ["spec", "i32", "i64", "literals"],
)

